# Comma-separated CoinGecko coin ids — one HTTP GET per poll round, then one DB row per coin.
COIN_IDS=bitcoin

# Multi-coin example (uncomment / edit as needed):
# COIN_IDS=bitcoin,ethereum,solana

# If COIN_IDS is unset or empty, COIN_ID is used for a single coin (backward compatible).
# COIN_ID=bitcoin

# Quote currency
VS_CURRENCY=usd

# Seconds between full poll rounds (one CoinGecko GET per round for all COIN_IDS).
# Without COINGECKO_API_KEY, use ~20+ (default 30); lower values often get HTTP 429 — see README.
POLL_INTERVAL_SEC=30

# Optional: CoinGecko Demo API key (header x-cg-demo-api-key) — higher limits
# COINGECKO_API_KEY=

# Alert when |change| from previous snapshot exceeds this percent
PRICE_ALERT_THRESHOLD_PERCENT=1.0

# SQLite path (relative to project root)
DATABASE_PATH=data/monitor.db
